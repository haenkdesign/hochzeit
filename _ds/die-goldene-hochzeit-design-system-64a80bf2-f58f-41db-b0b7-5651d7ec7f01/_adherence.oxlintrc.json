{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/brand/**",
              "components/core/**",
              "components/forms/**",
              "ui_kits/festival-site/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Baloo 2|Caveat|Nunito))/i]",
        "message": "Font not provided by the design system. Available: Baloo 2, Caveat, Nunito."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|outline|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone, outline."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:red|gold|pink|ink)$/]",
        "message": "<Badge> tone must be one of 'red' | 'gold' | 'pink' | 'ink'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|sticker|disabled|as|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, sticker, disabled, as."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|gold|ghost|pink)$/]",
        "message": "<Button> variant must be one of 'primary' | 'gold' | 'ghost' | 'pink'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:button|a)$/]",
        "message": "<Button> as must be one of 'button' | 'a'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|look|accent|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, look, accent."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='look'] > Literal[value!=/^(?:soft|sticker|flat)$/]",
        "message": "<Card> look must be one of 'soft' | 'sticker' | 'flat'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|checked|defaultChecked|onChange|disabled|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: label, checked, defaultChecked, onChange, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='Gingham'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|size|radius|key|ref|className|style|children)$/]",
        "message": "<Gingham> doesn't accept that prop. Declared props: children, size, radius."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|error|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, hint, error."
      },
      {
        "selector": "JSXOpeningElement[name.name='Logo'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|tone|src|height|alt|key|ref|className|style|children)$/]",
        "message": "<Logo> doesn't accept that prop. Declared props: variant, tone, src, height, alt."
      },
      {
        "selector": "JSXOpeningElement[name.name='Logo'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:wordmark|monogram)$/]",
        "message": "<Logo> variant must be one of 'wordmark' | 'monogram'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Logo'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:ink|cream|gold)$/]",
        "message": "<Logo> tone must be one of 'ink' | 'cream' | 'gold'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Scatter'] > JSXAttribute > JSXIdentifier[name!=/^(?:density|color|seed|key|ref|className|style|children)$/]",
        "message": "<Scatter> doesn't accept that prop. Declared props: density, color, seed."
      },
      {
        "selector": "JSXOpeningElement[name.name='Ticket'] > JSXAttribute > JSXIdentifier[name!=/^(?:eyebrow|title|price|meta|stub|tone|children|key|ref|className|style|children)$/]",
        "message": "<Ticket> doesn't accept that prop. Declared props: eyebrow, title, price, meta, stub, tone, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Ticket'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:cream|red)$/]",
        "message": "<Ticket> tone must be one of 'cream' | 'red'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
